# 경로: backend/.env.example
# 이 파일을 복사해 backend/.env 를 만들고 실제 값으로 채우세요.
#   cp .env.example .env
# .env 는 절대 git 에 커밋하지 마세요(.gitignore 등록).

# --- 앱 ---
APP_ENV=local
DEBUG=true
CORS_ORIGINS=*

# --- DB (Supabase Postgres + PostGIS) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stardust

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=sky

# --- 내부 JWT (운영 시 강력한 무작위 값으로 교체) ---
JWT_SECRET=CHANGE_ME_super_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# --- 소셜 로그인 검증 ---
GOOGLE_CLIENT_ID=
APPLE_BUNDLE_ID=
KAKAO_REST_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- 한국관광공사 OpenAPI ---
KTO_SERVICE_KEY=
KTO_BASE_URL=https://apis.data.go.kr/B551011/KorService2
KTO_DEFAULT_AREA_CODE=32

# TMAP(SK open API) 보행자 경로 — 도보안내. 미설정이면 직선 폴백
TMAP_APP_KEY=
