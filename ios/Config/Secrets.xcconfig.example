// 경로: ios/Config/Secrets.xcconfig.example
// 이 파일을 복사해 같은 폴더에 Secrets.xcconfig 를 만들고 실제 값으로 채우세요.
//   cp Secrets.xcconfig.example Secrets.xcconfig
// Secrets.xcconfig 는 .gitignore 에 등록되어 커밋되지 않습니다.
//
// 네이버 로그인(네아로) — Naver Developers 애플리케이션의 Client ID / Secret.

NAVER_CONSUMER_KEY = your-naver-client-id
NAVER_CONSUMER_SECRET = your-naver-client-secret
