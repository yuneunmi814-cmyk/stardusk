// 경로: ios/Config/Debug.xcconfig
// 디버그 빌드도 운영 서버(Render)를 가리킨다 — 로컬 백엔드를 띄우지 않고
// 배포 서버로 바로 테스트하기 위함. (`//` 는 `$()` 로 끊어 표기)
//    빌드 시 결과: https://stardust-api-ts8t.onrender.com/api/v1
// ※ 로컬 백엔드로 개발하려면 이 값을 http:/$()/localhost:8000/api/v1 로 되돌리면 된다.

STARDUST_API_BASE_URL = https:/$()/stardust-api-ts8t.onrender.com/api/v1
