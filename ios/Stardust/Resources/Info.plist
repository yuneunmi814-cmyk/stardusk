<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>ko</string>
	<key>CFBundleDisplayName</key>
	<string>STARDUST</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<!-- 표준 HTTPS/TLS 만 사용(수출 규정 면제) → 업로드 시 암호화 질문 자동 처리 -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
	</dict>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string></string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>

	<!-- ===== 권한 사용 설명 (필수 2 / 선택 3) ===== -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>당신이 머문 자리에 별을 띄우기 위해 위치를 사용해요.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>목적지에 도착하면 알려드리기 위해 위치를 사용해요.</string>
	<key>NSCameraUsageDescription</key>
	<string>하늘을 담기 위해 카메라를 사용해요.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>그날의 하늘과 현장음까지 생생하게 담기 위해 마이크를 사용해요.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>담은 하늘을 사진 보관함에도 저장하기 위해 사용해요.</string>

	<!-- ===== 백그라운드 도착 감지(지오펜스) ===== -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
	</array>

	<!-- ===== 외부 지도 앱 + 카카오톡/네이버 로그인(딥링크 조회용) ===== -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>nmap</string>
		<string>kakaomap</string>
		<string>tmap</string>
		<string>kakaokakaotalk</string>
		<string>kakaoplus</string>
		<string>naversearchapp</string>
		<string>naversearchthirdlogin</string>
	</array>

	<!-- ===== 네이버 로그인(네아로) — 자격증명은 gitignore된 Secrets.xcconfig 에서 주입 ===== -->
	<key>NAVER_CONSUMER_KEY</key>
	<string>$(NAVER_CONSUMER_KEY)</string>
	<key>NAVER_CONSUMER_SECRET</key>
	<string>$(NAVER_CONSUMER_SECRET)</string>

	<!-- ===== 소셜 로그인 URL scheme (Google reversed client ID + 카카오 네이티브 앱 키) ===== -->
	<!-- 모두 앱 내장 식별자(secret 아님). -->
	<key>GIDClientID</key>
	<string>739267607865-3epq5qebmvleph52obrub2854hcekn1f.apps.googleusercontent.com</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.739267607865-3epq5qebmvleph52obrub2854hcekn1f</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>kakaoc5b7d136888b761bd4218b2414a04f37</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>stardust</string>
			</array>
		</dict>
	</array>

	<!-- ===== 백엔드 Base URL (빌드 구성별: Config/*.xcconfig 에서 주입) ===== -->
	<key>STARDUST_API_BASE_URL</key>
	<string>$(STARDUST_API_BASE_URL)</string>

	<!-- ===== App Transport Security ===== -->
	<!-- 운영 트래픽은 HTTPS 강제. 개발용 localhost 평문 HTTP 만 예외 허용. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
